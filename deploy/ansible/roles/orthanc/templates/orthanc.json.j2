{
  "_comment": "Test Orthanc for the DICOMweb spike. SEPARATE from the miniChRIS bundled orthanc. Generated by Ansible -- do not edit by hand.",
  "Name": "DICOMweb Spike Test PACS",

  "// ---- HTTP / REST ----": "REST API + Orthanc Explorer + DICOMweb plugin all served here",
  "HttpServerEnabled": true,
  "HttpPort": 8042,
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,

  "// ---- DIMSE (classic DICOM) ----": "C-STORE/C-ECHO/C-FIND listener",
  "DicomServerEnabled": true,
  "DicomAet": "{{ test_orthanc_aet }}",
  "DicomPort": 4242,
  "DicomCheckModalityHost": false,
  "DicomAlwaysAllowStore": true,
  "DicomAlwaysAllowEcho": true,

  "// ---- Downstream modalities ----": "Register oxidicom (AET ChRIS) so we can C-STORE-push studies into CUBE",
  "DicomModalities": {
    "ChRIS": ["{{ oxidicom_aet }}", "{{ oxidicom_internal_host }}", {{ oxidicom_internal_port }}]
  },

  "// ---- Plugins ----": "DicomWeb (QIDO/WADO/STOW) + the bundled REST API. orthancteam image ships these plugins.",
  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "WadoRoot": "/wado",
    "Ssl": false,
    "StowMaxInstances": 0,
    "StowMaxSize": 0
  },

  "StorageDirectory": "/var/lib/orthanc/db",
  "IndexDirectory": "/var/lib/orthanc/db",
  "StorageCompression": false,
  "OverwriteInstances": true
}
